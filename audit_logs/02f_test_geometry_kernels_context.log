    94	def test_aabb_contains_inside_outside_and_touching_boundary():
    95	    for dtype in (np.float32, np.float64):
    96	        outer_min = np.array([0.0, 0.0, 0.0], dtype=dtype)
    97	        outer_max = np.array([1.0, 1.0, 1.0], dtype=dtype)
    98	
    99	        assert kernels.aabb_contains(
   100	            outer_min,
   101	            outer_max,
   102	            np.array([0.25, 0.25, 0.25], dtype=dtype),
   103	            np.array([0.75, 0.75, 0.75], dtype=dtype),
   104	        )
   105	        assert not kernels.aabb_contains(
   106	            outer_min,
   107	            outer_max,
   108	            np.array([-0.1, 0.25, 0.25], dtype=dtype),
   109	            np.array([0.75, 0.75, 0.75], dtype=dtype),
   110	        )
   111	        assert kernels.aabb_contains(
   112	            outer_min,
   113	            outer_max,
   114	            np.array([0.0, 0.0, 0.0], dtype=dtype),
   115	            np.array([1.0, 1.0, 1.0], dtype=dtype),
   116	        )
