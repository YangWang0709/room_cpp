   119	def test_empty_arrays_raise_value_error():
   120	    empty = np.empty((0, 3), dtype=np.float64)
   121	    one_box_min = np.array([[0.0, 0.0, 0.0]], dtype=np.float64)
   122	    one_box_max = np.array([[1.0, 1.0, 1.0]], dtype=np.float64)
   123	
   124	    with pytest.raises(ValueError, match="at least one row"):
   125	        kernels.bbox_min_max(empty)
   126	    with pytest.raises(ValueError, match="at least one row"):
   127	        kernels.bbox_union(empty, empty)
   128	    with pytest.raises(ValueError, match="at least one row"):
   129	        kernels.aabb_overlap_matrix(empty, empty, one_box_min, one_box_max)
   130	    with pytest.raises(ValueError, match="at least one row"):
   131	        kernels.aabb_overlap_matrix(one_box_min, one_box_max, empty, empty)
   132	
