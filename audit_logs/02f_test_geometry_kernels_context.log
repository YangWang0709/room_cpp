    45	def test_aabb_overlap_matrix_hand_cases():
    46	    mins_a_base = np.array(
    47	        [
    48	            [0.0, 0.0, 0.0],
    49	            [2.0, 2.0, 2.0],
    50	        ]
    51	    )
    52	    maxs_a_base = np.array(
    53	        [
    54	            [1.0, 1.0, 1.0],
    55	            [3.0, 3.0, 3.0],
    56	        ]
    57	    )
    58	    mins_b_base = np.array(
    59	        [
    60	            [0.5, 0.5, 0.5],
    61	            [1.0, 1.0, 1.0],
    62	            [1.1, 0.0, 0.0],
    63	            [3.0, 3.0, 3.0],
    64	        ]
    65	    )
    66	    maxs_b_base = np.array(
    67	        [
    68	            [2.0, 2.0, 2.0],
    69	            [2.0, 2.0, 2.0],
    70	            [2.0, 1.0, 1.0],
    71	            [4.0, 4.0, 4.0],
    72	        ]
    73	    )
    74	
    75	    expected = np.array(
    76	        [
    77	            [True, True, False, False],
    78	            [True, True, False, True],
    79	        ],
    80	        dtype=np.bool_,
    81	    )
    82	    for dtype in (np.float32, np.float64):
    83	        np.testing.assert_array_equal(
    84	            kernels.aabb_overlap_matrix(
    85	                mins_a_base.astype(dtype),
    86	                maxs_a_base.astype(dtype),
    87	                mins_b_base.astype(dtype),
    88	                maxs_b_base.astype(dtype),
    89	            ),
    90	            expected,
    91	        )
    92	
