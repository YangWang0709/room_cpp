   134	def test_python_fallback_and_cython_outputs_match_when_available():
   135	    points = np.array(
   136	        [
   137	            [-1.0, 2.0, 0.0],
   138	            [3.0, -4.0, 5.0],
   139	            [0.5, 1.5, -2.5],
   140	        ],
   141	        dtype=np.float64,
   142	    )
   143	    mins = np.array(
   144	        [[-1.0, 0.0, 0.0], [2.0, 2.0, 2.0]],
   145	        dtype=np.float64,
   146	    )
   147	    maxs = np.array(
   148	        [[1.0, 1.0, 1.0], [4.0, 4.0, 4.0]],
   149	        dtype=np.float64,
   150	    )
   151	
   152	    py_min, py_max = kernels.bbox_min_max_py(points)
   153	    py_union_min, py_union_max = kernels.bbox_union_py(mins, maxs)
   154	    py_overlap = kernels.aabb_overlap_matrix_py(mins, maxs, mins, maxs)
   155	    py_contains = kernels.aabb_contains_py(mins[0], maxs[0], mins[0], maxs[0])
   156	
   157	    if not kernels.C_EXTENSION_AVAILABLE:
   158	        assert kernels.bbox_min_max(points)[0].shape == (3,)
   159	        assert py_overlap.dtype == np.bool_
   160	        pytest.skip(f"Cython extension unavailable: {kernels.C_EXTENSION_ERROR}")
   161	
   162	    cpp_min, cpp_max = kernels.bbox_min_max_cpp(points)
   163	    cpp_union_min, cpp_union_max = kernels.bbox_union_cpp(mins, maxs)
   164	    cpp_overlap = kernels.aabb_overlap_matrix_cpp(mins, maxs, mins, maxs)
   165	    cpp_contains = kernels.aabb_contains_cpp(mins[0], maxs[0], mins[0], maxs[0])
   166	
   167	    np.testing.assert_allclose(cpp_min, py_min)
   168	    np.testing.assert_allclose(cpp_max, py_max)
   169	    np.testing.assert_allclose(cpp_union_min, py_union_min)
   170	    np.testing.assert_allclose(cpp_union_max, py_union_max)
   171	    np.testing.assert_array_equal(cpp_overlap, py_overlap)
   172	    assert cpp_contains == py_contains
