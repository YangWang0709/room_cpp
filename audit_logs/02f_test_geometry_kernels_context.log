     1	import numpy as np
     2	import pytest
     3	
     4	from infinigen.core.constraints.cpp import geometry_kernels as kernels
     5	
     6	
     7	def test_bbox_min_max_matches_numpy_for_float32_and_float64():
     8	    base = np.array(
     9	        [
    10	            [1.0, -2.0, 3.5],
    11	            [-4.0, 5.0, 0.25],
    12	            [2.5, 1.0, -7.0],
    13	        ]
    14	    )
    15	    for dtype in (np.float32, np.float64):
    16	        points = base.astype(dtype)
    17	        mins, maxs = kernels.bbox_min_max(points)
    18	        np.testing.assert_allclose(mins, np.min(points, axis=0))
    19	        np.testing.assert_allclose(maxs, np.max(points, axis=0))
    20	
    21	
    22	def test_bbox_union_matches_numpy_for_float32_and_float64():
    23	    mins_base = np.array(
    24	        [
    25	            [0.0, 0.0, -1.0],
    26	            [-2.0, 1.0, 0.0],
    27	            [1.0, -3.0, 2.0],
    28	        ]
    29	    )
    30	    maxs_base = np.array(
    31	        [
    32	            [1.0, 2.0, 0.0],
    33	            [-1.0, 4.0, 3.0],
    34	            [3.0, -2.0, 5.0],
    35	        ]
    36	    )
    37	    for dtype in (np.float32, np.float64):
    38	        mins = mins_base.astype(dtype)
    39	        maxs = maxs_base.astype(dtype)
    40	        union_min, union_max = kernels.bbox_union(mins, maxs)
    41	        np.testing.assert_allclose(union_min, np.min(mins, axis=0))
    42	        np.testing.assert_allclose(union_max, np.max(maxs, axis=0))
    43	
