   214	def _mesh_digest(mesh: trimesh.Trimesh) -> str:
   215	    digest = hashlib.blake2b(digest_size=12)
   216	    vertices = np.ascontiguousarray(np.asarray(mesh.vertices))
   217	    faces = np.ascontiguousarray(np.asarray(mesh.faces))
   218	    digest.update(str(vertices.dtype).encode("utf-8"))
   219	    digest.update(str(vertices.shape).encode("utf-8"))
   220	    digest.update(vertices.tobytes())
   221	    digest.update(str(faces.dtype).encode("utf-8"))
   222	    digest.update(str(faces.shape).encode("utf-8"))
   223	    digest.update(faces.tobytes())
   224	    return digest.hexdigest()
   225	
   226	
   227	def _record_trimesh_complexity(
   228	    row: dict, base_factory_class: str, mesh: trimesh.Trimesh
   229	):
   230	    vertex_count = len(mesh.vertices)
   231	    face_count = len(mesh.faces)
   232	    edge_count = len(mesh.edges_unique)
   233	    row["mesh_vertex_count"] = vertex_count
   234	    row["mesh_face_count"] = face_count
   235	    row["mesh_edge_count"] = edge_count
   236	
   237	    bounds = np.asarray(mesh.bounds, dtype=float)
   238	    if bounds.shape == (2, 3):
   239	        mins = bounds[0]
   240	        maxs = bounds[1]
   241	        extents = maxs - mins
   242	        for axis, value in zip(("x", "y", "z"), mins):
   243	            row[f"bbox_min_{axis}"] = float(value)
   244	        for axis, value in zip(("x", "y", "z"), maxs):
   245	            row[f"bbox_max_{axis}"] = float(value)
   246	        for axis, value in zip(("x", "y", "z"), extents):
   247	            row[f"bbox_extent_{axis}"] = float(value)
   248	
   249	    extent_key = ",".join(
   250	        f"{float(row.get(f'bbox_extent_{axis}', 0.0)):.6g}"
   251	        for axis in ("x", "y", "z")
   252	    )
   253	    row["stable_pose_cache_candidate_key"] = (
   254	        f"{base_factory_class}|v={vertex_count}|f={face_count}|e={edge_count}|"
   255	        f"extent={extent_key}|mesh={_mesh_digest(mesh)}"
   256	    )
   257	
