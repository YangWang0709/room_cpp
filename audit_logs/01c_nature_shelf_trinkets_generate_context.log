   290	        "bbox_min_x": "",
   291	        "bbox_min_y": "",
   292	        "bbox_min_z": "",
   293	        "bbox_max_x": "",
   294	        "bbox_max_y": "",
   295	        "bbox_max_z": "",
   296	        "bbox_extent_x": "",
   297	        "bbox_extent_y": "",
   298	        "bbox_extent_z": "",
   299	        "stable_pose_count": "",
   300	        "stable_pose_best_prob": "",
   301	        "stable_pose_cache_candidate_key": "",
   302	        "asset_children_before_join": "",
   303	        "asset_tree_object_count_after_spawn": "",
   304	        "final_asset_name": "",
   305	        "final_asset_type": "",
   306	        "final_asset_mesh_name": "",
   307	        "final_asset_child_count": "",
   308	        "success": False,
   309	        "error_type": "",
   310	    }
   311	    for key, names in before_sets.items():
   312	        row[f"{key}_count_before"] = len(names)
