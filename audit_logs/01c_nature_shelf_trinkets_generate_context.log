   261	    inst_seed,
   262	    placeholder,
   263	    before_sets: dict[str, set[str]],
   264	) -> dict:
   265	    row = {
   266	        "factory_class": factory.__class__.__name__,
   267	        "base_factory_class": factory.base_factory.__class__.__name__,
   268	        "factory_seed": getattr(factory, "factory_seed", ""),
   269	        "inst_seed": inst_seed,
   270	        "base_inst_seed": "",
   271	        "placeholder_name": _placeholder_name(placeholder),
   272	        "create_asset_total_duration": 0.0,
   273	        "base_factory_spawn_duration": 0.0,
   274	        "join_children_duration": 0.0,
   275	        "apply_initial_transform_duration": 0.0,
   276	        "apply_modifiers_duration": 0.0,
   277	        "obj2trimesh_duration": 0.0,
   278	        "stable_pose_duration": 0.0,
   279	        "fast_stable_pose_duration": 0.0,
   280	        "apply_rotation_transform_duration": 0.0,
   281	        "scale_and_position_duration": 0.0,
   282	        "apply_final_location_transform_duration": 0.0,
   283	        "fast_stable_pose_enabled": _fast_nature_trinket_stable_pose_enabled(),
   284	        "fast_stable_pose_used": False,
   285	        "stable_pose_mode": "original",
   286	        "skipped_compute_stable_poses": False,
   287	        "mesh_vertex_count": "",
