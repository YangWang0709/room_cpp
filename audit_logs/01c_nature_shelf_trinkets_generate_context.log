   315	
   316	def _finish_timing_row(row: dict, before_sets: dict[str, set[str]]):
   317	    after_sets = _bpy_datablock_name_sets()
   318	    for key, before_names in before_sets.items():
   319	        after_names = after_sets[key]
   320	        row[f"{key}_count_after"] = len(after_names)
   321	        row[f"created_{key}_count"] = len(after_names - before_names)
   322	
   323	    for key in ("material", "texture", "node_group"):
   324	        created_names = sorted(after_sets[key] - before_sets[key])
   325	        row[f"created_{key}_names"] = ";".join(created_names)
   326	
   327	    _write_nature_shelf_trinkets_timing_row(row)
