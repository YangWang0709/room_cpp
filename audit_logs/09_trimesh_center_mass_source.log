   560	        unlike self.center_mass
   561	
   562	        Returns
   563	        ----------
   564	        centroid : (3, ) float
   565	          The average vertex weighted by face area
   566	        """
   567	
   568	        # use the centroid of each triangle weighted by
   569	        # the area of the triangle to find the overall centroid
   570	        try:
   571	            centroid = np.average(self.triangles_center,
   572	                                  weights=self.area_faces,
   573	                                  axis=0)
   574	        except BaseException:
   575	            # if all triangles are zero-area weights will not work
   576	            centroid = self.triangles_center.mean(axis=0)
   577	        return centroid
