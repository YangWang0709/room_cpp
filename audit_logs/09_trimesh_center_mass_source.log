   585	        garbage unless it was explicitly set.
   586	
   587	        Returns
   588	        -----------
   589	        center_mass : (3, ) float
   590	           Volumetric center of mass of the mesh
   591	        """
   592	        center_mass = self.mass_properties['center_mass']
   593	        return center_mass
   594	
   595	    @center_mass.setter
   596	    def center_mass(self, cm):
