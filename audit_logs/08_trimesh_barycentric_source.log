   450	
   451	    if not util.is_shape(triangles, (-1, 3, 3)):
   452	        raise ValueError('Triangles must be (n, 3, 3)!')
   453	    if barycentric.shape == (2,):
   454	        barycentric = np.ones((len(triangles), 2),
   455	                              dtype=np.float64) * barycentric
   456	    if util.is_shape(barycentric, (len(triangles), 2)):
   457	        barycentric = np.column_stack((barycentric,
   458	                                       1.0 - barycentric.sum(axis=1)))
   459	    elif not util.is_shape(barycentric, (len(triangles), 3)):
   460	        raise ValueError('Barycentric shape incorrect!')
   461	
   462	    barycentric /= barycentric.sum(axis=1).reshape((-1, 1))
   463	    points = (triangles * barycentric.reshape((-1, 3, 1))).sum(axis=1)
   464	
   465	    return points
   466	
   467	
   468	def points_to_barycentric(triangles,
   469	                          points,
   470	                          method='cramer'):
   471	    """
   472	    Find the barycentric coordinates of points relative to triangles.
   473	
   474	    The Cramer's rule solution implements:
   475	        http://blackpawn.com/texts/pointinpoly
   476	
   477	    The cross product solution implements:
   478	        https://www.cs.ubc.ca/~heidrich/Papers/JGT.05.pdf
   479	
   480	
   481	    Parameters
   482	    -----------
   483	    triangles : (n, 3, 3) float
   484	      Triangles vertices in space
   485	    points : (n, 3) float
   486	      Point in space associated with a triangle
   487	    method :  str
   488	      Which method to compute the barycentric coordinates with:
   489	        - 'cross': uses a method using cross products, roughly 2x slower but
   490	                  different numerical robustness properties
   491	        - anything else: uses a cramer's rule solution
   492	
   493	    Returns
   494	    -----------
   495	    barycentric : (n, 3) float
   496	      Barycentric coordinates of each point
   497	    """
   498	
   499	    def method_cross():
   500	        n = np.cross(edge_vectors[:, 0], edge_vectors[:, 1])
   501	        denominator = diagonal_dot(n, n)
   502	
   503	        barycentric = np.zeros((len(triangles), 3), dtype=np.float64)
   504	        barycentric[:, 2] = diagonal_dot(
   505	            np.cross(edge_vectors[:, 0], w), n) / denominator
   506	        barycentric[:, 1] = diagonal_dot(
   507	            np.cross(w, edge_vectors[:, 1]), n) / denominator
   508	        barycentric[:, 0] = 1 - barycentric[:, 1] - barycentric[:, 2]
   509	        return barycentric
   510	
   511	    def method_cramer():
   512	        dot00 = diagonal_dot(edge_vectors[:, 0], edge_vectors[:, 0])
   513	        dot01 = diagonal_dot(edge_vectors[:, 0], edge_vectors[:, 1])
   514	        dot02 = diagonal_dot(edge_vectors[:, 0], w)
   515	        dot11 = diagonal_dot(edge_vectors[:, 1], edge_vectors[:, 1])
   516	        dot12 = diagonal_dot(edge_vectors[:, 1], w)
   517	
   518	        inverse_denominator = 1.0 / (dot00 * dot11 - dot01 * dot01)
   519	
   520	        barycentric = np.zeros((len(triangles), 3), dtype=np.float64)
   521	        barycentric[:, 2] = (dot00 * dot12 - dot01 *
   522	                             dot02) * inverse_denominator
   523	        barycentric[:, 1] = (dot11 * dot02 - dot01 *
   524	                             dot12) * inverse_denominator
   525	        barycentric[:, 0] = 1 - barycentric[:, 1] - barycentric[:, 2]
   526	        return barycentric
   527	
   528	    # establish that input triangles and points are sane
   529	    triangles = np.asanyarray(triangles, dtype=np.float64)
   530	    points = np.asanyarray(points, dtype=np.float64)
   531	    if not util.is_shape(triangles, (-1, 3, 3)):
   532	        raise ValueError('triangles shape incorrect')
   533	    if not util.is_shape(points, (len(triangles), 3)):
   534	        raise ValueError('triangles and points must correspond')
   535	
   536	    edge_vectors = triangles[:, 1:] - triangles[:, :1]
   537	    w = points - triangles[:, 0].reshape((-1, 3))
   538	
   539	    if method == 'cross':
   540	        return method_cross()
