     1	# cython: boundscheck=False, wraparound=False, initializedcheck=False, cdivision=True, language_level=3
     2	"""Cython/C++ pure numeric geometry kernels.
     3	
     4	This module intentionally avoids Blender, gin, solver code, and random number
     5	generation. Boundary contact is treated as inclusive overlap/containment.
     6	"""
     7	
     8	import numpy as np
     9	cimport numpy as cnp
    10	
    11	cnp.import_array()
    12	
    13	cdef object _NP_FLOAT32 = np.dtype(np.float32)
    14	cdef object _NP_FLOAT64 = np.dtype(np.float64)
    15	
    16	
    17	cdef object _as_2d3(str name, object value):
    18	    cdef object arr = np.asarray(value)
    19	    if arr.ndim != 2 or arr.shape[1] != 3:
    20	        raise ValueError(f"{name} must have shape [N, 3], got {arr.shape}")
    21	    if arr.shape[0] == 0:
    22	        raise ValueError(f"{name} must contain at least one row")
    23	    if arr.dtype != _NP_FLOAT32 and arr.dtype != _NP_FLOAT64:
    24	        raise TypeError(f"{name} must have dtype float32 or float64, got {arr.dtype}")
    25	    return arr
    26	
    27	
    28	cdef object _as_1d3(str name, object value):
    29	    cdef object arr = np.asarray(value)
    30	    if arr.shape != (3,):
    31	        raise ValueError(f"{name} must have shape [3], got {arr.shape}")
    32	    if arr.dtype != _NP_FLOAT32 and arr.dtype != _NP_FLOAT64:
    33	        raise TypeError(f"{name} must have dtype float32 or float64, got {arr.dtype}")
    34	    return arr
    35	
    36	
    37	cdef object _promoted_dtype(tuple arrays):
    38	    cdef object dtype = np.dtype(np.result_type(*[arr.dtype for arr in arrays]))
    39	    if dtype != _NP_FLOAT32 and dtype != _NP_FLOAT64:
    40	        raise TypeError(
    41	            "inputs must have dtype float32 or float64, got "
    42	            + ", ".join(str(arr.dtype) for arr in arrays)
    43	        )
    44	    return dtype
