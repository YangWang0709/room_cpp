   139	cdef tuple _bbox_union_f64(double[:, ::1] mins_in, double[:, ::1] maxs_in):
   140	    cdef Py_ssize_t n = mins_in.shape[0]
   141	    cdef Py_ssize_t i
   142	    cdef double min0 = mins_in[0, 0]
   143	    cdef double min1 = mins_in[0, 1]
   144	    cdef double min2 = mins_in[0, 2]
   145	    cdef double max0 = maxs_in[0, 0]
   146	    cdef double max1 = maxs_in[0, 1]
   147	    cdef double max2 = maxs_in[0, 2]
   148	    cdef double v0, v1, v2
   149	    cdef cnp.ndarray[cnp.float64_t, ndim=1] out_min
   150	    cdef cnp.ndarray[cnp.float64_t, ndim=1] out_max
   151	
   152	    for i in range(1, n):
   153	        v0 = mins_in[i, 0]
   154	        v1 = mins_in[i, 1]
   155	        v2 = mins_in[i, 2]
   156	        if v0 < min0:
   157	            min0 = v0
   158	        if v1 < min1:
   159	            min1 = v1
   160	        if v2 < min2:
   161	            min2 = v2
   162	        v0 = maxs_in[i, 0]
   163	        v1 = maxs_in[i, 1]
   164	        v2 = maxs_in[i, 2]
   165	        if v0 > max0:
   166	            max0 = v0
   167	        if v1 > max1:
   168	            max1 = v1
   169	        if v2 > max2:
   170	            max2 = v2
   171	
   172	    out_min = np.empty(3, dtype=np.float64)
   173	    out_max = np.empty(3, dtype=np.float64)
   174	    out_min[0] = min0
   175	    out_min[1] = min1
   176	    out_min[2] = min2
   177	    out_max[0] = max0
   178	    out_max[1] = max1
   179	    out_max[2] = max2
   180	    return out_min, out_max
