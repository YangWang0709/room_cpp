    47	cdef tuple _bbox_min_max_f64(double[:, ::1] points):
    48	    cdef Py_ssize_t n = points.shape[0]
    49	    cdef Py_ssize_t i
    50	    cdef double min0 = points[0, 0]
    51	    cdef double min1 = points[0, 1]
    52	    cdef double min2 = points[0, 2]
    53	    cdef double max0 = min0
    54	    cdef double max1 = min1
    55	    cdef double max2 = min2
    56	    cdef double v0, v1, v2
    57	    cdef cnp.ndarray[cnp.float64_t, ndim=1] mins
    58	    cdef cnp.ndarray[cnp.float64_t, ndim=1] maxs
    59	
    60	    for i in range(1, n):
    61	        v0 = points[i, 0]
    62	        v1 = points[i, 1]
    63	        v2 = points[i, 2]
    64	        if v0 < min0:
    65	            min0 = v0
    66	        elif v0 > max0:
    67	            max0 = v0
    68	        if v1 < min1:
    69	            min1 = v1
    70	        elif v1 > max1:
    71	            max1 = v1
    72	        if v2 < min2:
    73	            min2 = v2
    74	        elif v2 > max2:
    75	            max2 = v2
    76	
    77	    mins = np.empty(3, dtype=np.float64)
    78	    maxs = np.empty(3, dtype=np.float64)
    79	    mins[0] = min0
    80	    mins[1] = min1
    81	    mins[2] = min2
    82	    maxs[0] = max0
    83	    maxs[1] = max1
    84	    maxs[2] = max2
    85	    return mins, maxs
