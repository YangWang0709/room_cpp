   129	def bbox_min_max(object points):
   130	    """Return coordinate-wise min and max for points shaped [N, 3]."""
   131	    cdef object points_arr = _as_2d3("points", points)
   132	    cdef object dtype = _promoted_dtype((points_arr,))
   133	    points_arr = np.ascontiguousarray(points_arr, dtype=dtype)
   134	    if dtype == _NP_FLOAT64:
   135	        return _bbox_min_max_f64(points_arr)
   136	    return _bbox_min_max_f32(points_arr)
