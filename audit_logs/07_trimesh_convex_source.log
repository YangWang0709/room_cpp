   152	def adjacency_projections(mesh):
   153	    """
   154	    Test if a mesh is convex by projecting the vertices of
   155	    a triangle onto the normal of its adjacent face.
   156	
   157	    Parameters
   158	    ----------
   159	    mesh : Trimesh
   160	      Input geometry
   161	
   162	    Returns
   163	    ----------
   164	    projection : (len(mesh.face_adjacency),) float
   165	      Distance of projection of adjacent vertex onto plane
   166	    """
   167	    # normals and origins from the first column of face adjacency
   168	    normals = mesh.face_normals[mesh.face_adjacency[:, 0]]
   169	    # one of the vertices on the shared edge
   170	    origins = mesh.vertices[mesh.face_adjacency_edges[:, 0]]
